# --- Konnex subnet ---
NETUID=4
SUBTENSOR_CHAIN_ENDPOINT=wss://testnet-rpc1.konnex.world:39944

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=openai/gpt-5.4-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://konnex.world
OPENROUTER_X_TITLE=konnex-miner
# Concurrent in-flight requests to OpenRouter across ALL wallets
OPENROUTER_CONCURRENCY=200
OPENROUTER_TIMEOUT_SECONDS=45

# --- Wallets ---
WALLETS_DIR=./wallets
MNEMONICS_FILE=./mnemonics.txt
WALLETS_MANIFEST=./wallets.json
# Public IP of this VPS — written into the metagraph via axon.serve()
EXTERNAL_IP=
# First axon port; subsequent wallets use BASE+1, BASE+2, ...
AXON_PORT_BASE=8091

# --- Bootstrap (registration) ---
# Seconds to sleep between consecutive btcli registrations (avoid rate-limit)
REGISTER_DELAY_SECONDS=12
# If true, skip wallets already registered on the subnet
REGISTER_SKIP_IF_REGISTERED=true

# --- Runtime ---
METAGRAPH_SYNC_SECONDS=120
LOG_LEVEL=INFO
